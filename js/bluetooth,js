        content.push(this.createEscPosCommand('PENGIRIM:', { align: 'left', bold: true }));
        content.push(this.createEscPosCommand(`Nama: ${sender}`, { align: 'left' }));
        content.push(this.createEscPosCommand(`No Rek: ${senderAcc}`, { align: 'left' }));
        content.push(this.createEscPosCommand(`Bank: ${bankFrom}`, { align: 'left' }));
        content.push(this.createEscPosCommand(this.DASH, { align: 'center' }));

        content.push(this.createEscPosCommand('PENERIMA:', { align: 'left', bold: true }));
        content.push(this.createEscPosCommand(`Nama: ${receiver}`, { align: 'left' }));
        content.push(this.createEscPosCommand(`No Rek: ${receiverAcc}`, { align: 'left' }));
        content.push(this.createEscPosCommand(`Bank: ${bankTo}`, { align: 'left' }));
        content.push(this.createEscPosCommand(this.DASH, { align: 'center' }));

        content.push(this.createEscPosCommand(`Nominal: Rp ${this.formatNumber(nominal)}`, { align: 'right' }));
        content.push(this.createEscPosCommand(`Admin: Rp ${this.formatNumber(admin)}`, { align: 'right' }));
        content.push(this.createEscPosCommand(this.DASH, { align: 'center' }));
        content.push(this.createEscPosCommand(`TOTAL: Rp ${this.formatNumber(nominal + admin)}`, { align: 'right', bold: true, doubleHeight: true }));

        content.push(this.createEscPosCommand(this.LINE, { align: 'center' }));
        content.push(this.createEscPosCommand(header.note || 'Terima kasih', { align: 'center' }));
        
        content.push(new Uint8Array([0x0A, 0x0A]));
        content.push(new Uint8Array([0x1D, 0x56, 0x41, 0x00]));

        const success = await this.printAuto(this.concatArrays(...content));
        if (success) {
            app.showToast('✅ Bukti transfer tercetak!');
        }
    },

